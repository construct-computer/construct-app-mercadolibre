{
  "id": "mercadolibre",
  "name": "MercadoLibre",
  "version": "1.0.0",
  "description": "Search products, compare prices, and get details from MercadoLibre across Latin America.",
  "author": {
    "name": "Construct Team"
  },
  "entry": "server.ts",
  "runtime": "deno",
  "transport": "stdio",
  "permissions": {
    "network": ["api.mercadolibre.com"]
  },
  "categories": ["shopping", "e-commerce"],
  "tags": ["mercadolibre", "shopping", "latin-america", "price-comparison", "argentina", "brazil", "mexico"],
  "tools": [
    { "name": "search_products", "description": "Search for products on MercadoLibre" },
    { "name": "get_product", "description": "Get detailed information about a specific product" },
    { "name": "get_category", "description": "Browse or list product categories" },
    { "name": "get_seller", "description": "Get seller reputation and details" },
    { "name": "compare_prices", "description": "Compare prices for a product across multiple listings" },
    { "name": "list_sites", "description": "List available MercadoLibre country sites" }
  ]
}
